<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.choongang.shoppingmall.mappers.OrderMapper">

    <!-- 주문서 작성 -->
    <insert id="insertOrders"
        parameterType="com.choongang.shoppingmall.vo.OrdersVO">
        INSERT INTO orders(order_id, user_id, order_date)
        VALUES (#{order_id}, #{user_id}, #{order_date})
    </insert>

    <!-- 주문서 완료페이지 작성 -->
    <insert id="insertOrderComplete"
        parameterType="com.choongang.shoppingmall.vo.Order_CompleteVO">
        INSERT INTO orders(order_complete_id, order_id, product_id, quantity,
        total_price)
        VALUES (#{order_complete_id}, #{order_id}, #{product_id}, #{quantity},
        #{total_price})
    </insert>

    <!-- 모든 주문 조회 -->
    <select id="selectAllOrders"
        resultType="com.choongang.shoppingmall.vo.OrdersVO">
        SELECT * FROM orders
    </select>

    <!-- 주문 ID로 주문 조회 -->
    <select id="selectOrderById" parameterType="int"
        resultType="com.choongang.shoppingmall.vo.OrdersVO">
        SELECT * FROM orders
        WHERE order_id = #{orderId}
    </select>

    <!-- 주문 완료 정보 조회 쿼리 -->
    <select id="selectOrderCompleteByOrderId" parameterType="int"
        resultType="com.choongang.shoppingmall.vo.Order_CompleteVO">
        SELECT * FROM order_complete WHERE order_id = #{orderId}
    </select>

</mapper>
